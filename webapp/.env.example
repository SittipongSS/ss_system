# ── Supabase ────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.

# Public (safe to expose to the browser) — used for Auth later.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose this. Used by API routes + migration script.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Storage bucket for uploaded map/brand files (must be a PUBLIC bucket).
# Defaults to "uploads" if unset.
SUPABASE_STORAGE_BUCKET=uploads

# ── File storage backend ────────────────────────────────────
# "supabase" (default) keeps uploads in Supabase Storage.
# "drive" stores new uploads on Google Drive (Shared Drive) — see DRIVE_STORAGE_PLAN.md.
STORAGE_BACKEND=supabase

# ── Google Drive (only when STORAGE_BACKEND=drive) ──────────
# Auth = Workload Identity Federation (Vercel OIDC → impersonate the service
# account). NO downloadable JSON key (org policy iam.disableServiceAccountKeyCreation).
# These values are NOT secret — they only point at the WIF pool + service account.
#
# audience = //iam.googleapis.com/projects/<PROJECT_NUMBER>/locations/global/workloadIdentityPools/<POOL>/providers/<PROVIDER>
GOOGLE_WIF_AUDIENCE=//iam.googleapis.com/projects/390750549158/locations/global/workloadIdentityPools/vercel-pool-prod/providers/vercel
GOOGLE_SA_EMAIL=ss-attachments@ss-system-storage.iam.gserviceaccount.com
# Shared Drive ID (from the Shared Drive URL: /drive/folders/<ID>). REQUIRED for drive.
GOOGLE_SHARED_DRIVE_ID=0AHmPv7Sg7PANUk9PVA
# (optional) put files under a subfolder of the Shared Drive instead of its root.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Google Chat notifications (GOOGLE_CHAT_PLAN.md เฟส 1) ──────────────────
# webhook URL ของแต่ละ space (สร้างจาก Manage webhooks ใน space) — เว้นว่าง = ปิดแจ้งเตือนเงียบ ๆ
CHAT_WEBHOOK_APPROVALS=
CHAT_WEBHOOK_SALES=
CHAT_WEBHOOK_PM=
# base URL ของระบบ ใช้ประกอบปุ่มลิงก์ในการ์ด (ไม่ตั้ง = การ์ดไม่มีปุ่มลิงก์)
APP_BASE_URL=
