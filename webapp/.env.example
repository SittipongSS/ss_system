# ── Supabase ────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.

# Public (safe to expose to the browser) — used for Auth later.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose this. Used by API routes + migration script.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Storage bucket for uploaded map/brand files (must be a PUBLIC bucket).
# Defaults to "uploads" if unset.
SUPABASE_STORAGE_BUCKET=uploads
